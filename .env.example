# =============================================================
# NoiseDC — variáveis de ambiente (MODELO)
# Copie para .env e preencha localmente. O .env NUNCA é versionado.
# =============================================================

# ---- Camada 1: aquisição ----
DISPOSITIVO_ID=snitch-01
DISPOSITIVO_HOST=<IP_OU_HOSTNAME_DO_DISPOSITIVO>
DISPOSITIVO_USUARIO=<USUARIO>
DISPOSITIVO_CHAVE_SSH=/caminho/local/para/chave
WIFI_SSID=<SSID_DA_REDE>
WIFI_SENHA=<SENHA_DA_REDE>

# ---- Caminhos locais ----
DIR_DADOS_BRUTOS=./data/raw
DIR_DADOS_PROCESSADOS=./data/processed
DIR_RESULTADOS=./results

# ---- Camada 4: Zabbix ----
ZABBIX_SERVER=<IP_OU_FQDN_DO_SERVIDOR_ZABBIX>
ZABBIX_PORTA=10051
ZABBIX_API_URL=https://<HOST_ZABBIX>/api_jsonrpc.php
ZABBIX_API_TOKEN=<TOKEN>
ZABBIX_HOST_PREFIXO=AC
ZABBIX_ITEM_ESTADO=acustico.estado
ZABBIX_ITEM_CONFIANCA=acustico.confianca
ZABBIX_CONFIANCA_MINIMA=0.80

# ---- Camada 4: Grafana ----
GRAFANA_URL=https://<HOST_GRAFANA>
GRAFANA_TOKEN=<TOKEN>

# ---- SNMP (métricas convencionais das evaporadoras) ----
SNMP_VERSAO=3
SNMP_USUARIO=<USUARIO_SNMPV3>
SNMP_SENHA_AUTH=<SENHA_AUTENTICACAO>
SNMP_SENHA_PRIV=<SENHA_PRIVACIDADE>
# Nunca versione comunidades SNMPv1/v2c em texto claro.
