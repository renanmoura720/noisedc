# =============================================================
# NoiseDC — .gitignore
# Projeto: monitoramento acústico de equipamentos de refrigeração
# =============================================================

# -------- 1. Segredos e configurações locais (NUNCA versionar) --------
.env
.env.*
!.env.example
*.env
secrets.*
credentials.json
client_secret*.json
service-account*.json
token.json
*.pem
*.key
*.p12
*.pfx
*.jks
id_rsa*
id_ed25519*
*.ppk
.netrc
.htpasswd

# Configurações preenchidas com dados institucionais reais
configs/config.yaml
configs/*.local.yaml
configs/zabbix.yaml
configs/grafana.yaml
!configs/*.example.yaml
!configs/params.yaml

# Exportações brutas de infraestrutura (contêm IPs, hosts, comunidades SNMP)
deploy/**/*.raw.*
deploy/**/*.original.*
deploy/**/*-export-*.json
deploy/**/*-export-*.xml
!deploy/**/*.sanitizado.*

# Credenciais de agente/sender
zabbix_agentd.conf
zabbix_agent2.conf
*.psk

# -------- 2. Dados (ficam no Google Drive, não no Git) --------
#
# ATENÇÃO — pegadinha do Git: quando um padrão exclui a PASTA em si (como
# "data/raw/", com barra final, ou "data/processed/**" alcançando a entrada de
# uma subpasta), o Git poda a travessia ali e nenhuma exceção "!" mais
# específica escrita depois consegue alcançar o que está dentro. Por isso cada
# bloco abaixo primeiro desexclui a própria pasta ("!data/raw/") antes de
# reexcluir e liberar arquivos específicos dentro dela.
data/raw/**
!data/raw/
!data/raw/.gitkeep

data/interim/**
!data/interim/
!data/interim/.gitkeep

data/external/**
!data/external/
!data/external/.gitkeep

data/processed/**
!data/processed/
!data/processed/metadados_processados.csv
!data/processed/amostras/
!data/processed/amostras/**

# Áudio e representações intermediárias
*.wav
*.flac
*.mp3
*.ogg
*.aac
*.m4a
*.raw
*.npy
*.npz
*.h5
*.hdf5
*.parquet
*.feather
*.tfrecord

# Exceções: amostras mínimas para teste e demonstração
!tests/fixtures/**/*.wav
!tests/fixtures/**/*.npy
!data/processed/amostras/**/*.npy
!docs/exemplos/**/*.wav

# -------- 3. Modelos treinados grandes --------
results/models/**
!results/models/.gitkeep
!results/models/*.joblib
*.pkl
*.pt
*.pth
*.onnx
*.ckpt
*.pb
mlruns/
wandb/

# -------- 4. Python --------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib60/
sdist/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
env/
ENV/
.python-version
pip-log.txt
pip-delete-this-directory.txt

# Testes e qualidade
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.dmypy.json

# -------- 5. Jupyter --------
.ipynb_checkpoints/
*-checkpoint.ipynb
profile_default/
ipython_config.py

# -------- 6. LaTeX (dissertação, abnTeX2) --------
*.aux
*.bbl
*.blg
*.brf
*.fdb_latexmk
*.fls
*.idx
*.ilg
*.ind
*.lof
*.log
*.lot
*.out
*.synctex.gz
*.toc
*.xdv
*.bcf
*.run.xml
*.nav
*.snm
*.vrb

# -------- 7. Sistema operacional e editores --------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
ehthumbs.db
*~
*.swp
*.swo
.idea/
.vscode/
!.vscode/extensions.json
*.sublime-workspace

# -------- 8. Diversos --------
*.log
logs/
tmp/
temp/
.cache/
node_modules/
*.zip
*.tar.gz
*.rar
*.7z
~$*.docx
~$*.xlsx
~$*.pptx
